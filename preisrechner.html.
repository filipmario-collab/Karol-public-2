<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Preisrechner – G&L Stickerei</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1a2456;
    --blue: #2e5bba;
    --light-blue: #5b8dd9;
    --gold: #c9a84c;
    --cream: #f9f6f0;
    --white: #ffffff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Lato', sans-serif; background: var(--cream); color: var(--navy); min-height: 100vh; }

  header {
    background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
    padding: 2rem;
    text-align: center;
    color: white;
  }
  .header-logo { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; }
  .header-logo span { color: var(--gold); }
  .header-title { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-top: 0.5rem; opacity: 0.85; }
  .header-sub { font-size: 0.85rem; opacity: 0.6; letter-spacing: 0.15em; text-transform: uppercase; margin-top: 0.5rem; }

  .calculator { max-width: 600px; margin: 3rem auto; padding: 0 1.5rem 3rem; }

  .card {
    background: var(--white);
    border-radius: 2px;
    padding: 2rem;
    margin-bottom: 1.5rem;
    border-top: 3px solid var(--gold);
    box-shadow: 0 2px 20px rgba(26,36,86,0.08);
  }

  .card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--navy);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-title::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 1.2rem;
    background: var(--gold);
    border-radius: 2px;
  }

  .field { margin-bottom: 1.2rem; }
  .field label {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--blue);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .options { display: flex; flex-direction: column; gap: 0.5rem; }
  .option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid #e0e5f0;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .option:hover { border-color: var(--light-blue); background: #f5f8ff; }
  .option.selected { border-color: var(--navy); background: #f0f3fa; }
  .option input[type="radio"] { display: none; }
  .option-dot {
    width: 16px; height: 16px;
    border: 2px solid #ccd0e0;
    border-radius: 50%;
    flex-shrink: 0;
    transition: all 0.2s;
    display: flex; align-items: center; justify-content: center;
  }
  .option.selected .option-dot { border-color: var(--navy); background: var(--navy); }
  .option.selected .option-dot::after { content: ''; width: 6px; height: 6px; background: white; border-radius: 50%; }
  .option-text { flex: 1; }
  .option-name { font-weight: 700; font-size: 0.9rem; color: var(--navy); }
  .option-desc { font-size: 0.8rem; color: #888; margin-top: 0.2rem; }
  .option-price { font-size: 0.85rem; font-weight: 700; color: var(--blue); }

  .qty-wrap { display: flex; align-items: center; gap: 1rem; }
  .qty-btn {
    width: 36px; height: 36px;
    border: 2px solid var(--navy);
    background: transparent;
    color: var(--navy);
    font-size: 1.2rem;
    cursor: pointer;
    border-radius: 2px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
    font-weight: 700;
  }
  .qty-btn:hover { background: var(--navy); color: white; }
  .qty-input {
    width: 80px;
    text-align: center;
    padding: 0.5rem;
    border: 2px solid #e0e5f0;
    border-radius: 2px;
    font-family: 'Lato', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
    outline: none;
  }
  .qty-input:focus { border-color: var(--navy); }

  /* Result */
  .result-card {
    background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
    border-radius: 2px;
    padding: 2rem;
    color: white;
  }
  .result-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    margin-bottom: 1.5rem;
    color: var(--gold);
  }
  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    font-size: 0.9rem;
  }
  .result-row:last-child { border-bottom: none; }
  .result-row .label { opacity: 0.7; }
  .result-row .value { font-weight: 700; }
  .result-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 2px solid var(--gold);
  }
  .result-total .label { font-size: 1rem; font-weight: 700; }
  .result-total .value { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--gold); }

  .note {
    margin-top: 1rem;
    font-size: 0.75rem;
    opacity: 0.55;
    line-height: 1.5;
    text-align: center;
  }

  .cta {
    margin-top: 1.5rem;
    width: 100%;
    padding: 1rem;
    background: var(--gold);
    color: var(--navy);
    border: none;
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    cursor: pointer;
    border-radius: 2px;
    transition: 0.3s;
    text-decoration: none;
    display: block;
    text-align: center;
  }
  .cta:hover { opacity: 0.85; }
</style>
</head>
<body>

<header>
  <div class="header-logo">G<span>&</span>L</div>
  <div class="header-title">Preisrechner</div>
  <div class="header-sub">Orientierungspreise · Exkl. MwSt.</div>
</header>

<div class="calculator">

  <div class="card">
    <div class="card-title">Motivgröße (Stickgröße)</div>
    <div class="options" id="size-options">
      <label class="option selected" onclick="selectOption('size', 'small', this)">
        <input type="radio" name="size" value="small" checked>
        <div class="option-dot"></div>
        <div class="option-text">
          <div class="option-name">Klein – bis 10 × 10 cm</div>
          <div class="option-desc">Brust, Ärmel, kleine Logos</div>
        </div>
        <div class="option-price">ab € 15,–</div>
      </label>
      <label class="option" onclick="selectOption('size', 'medium', this)">
        <input type="radio" name="size" value="medium">
        <div class="option-dot"></div>
        <div class="option-text">
          <div class="option-name">Mittel – bis 25 × 10 cm</div>
          <div class="option-desc">Rücken, größere Motive</div>
        </div>
        <div class="option-price">ab € 25,–</div>
      </label>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Programmierungsart</div>
    <div class="options" id="prog-options">
      <label class="option selected" onclick="selectOption('prog', 'standard', this)">
        <input type="radio" name="prog" value="standard" checked>
        <div class="option-dot"></div>
        <div class="option-text">
          <div class="option-name">Standardschrift</div>
          <div class="option-desc">Name, Schriftzug aus Standardfonts</div>
        </div>
        <div class="option-price">€ 25,–</div>
      </label>
      <label class="option" onclick="selectOption('prog', 'logo', this)">
        <input type="radio" name="prog" value="logo">
        <div class="option-dot"></div>
        <div class="option-text">
          <div class="option-name">Logo / individuelles Motiv</div>
          <div class="option-desc">Firmenlogo, eigenes Design</div>
        </div>
        <div class="option-price">€ 75,–</div>
      </label>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Anzahl der Stücke</div>
    <div class="field">
      <div class="qty-wrap">
        <button class="qty-btn" onclick="changeQty(-1)">−</button>
        <input type="number" class="qty-input" id="qty" value="1" min="1" max="999" oninput="calculate()">
        <button class="qty-btn" onclick="changeQty(1)">+</button>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Mengenstaffel (Množstevné zľavy)</div>
    <table style="width:100%; border-collapse: collapse; font-size: 0.85rem;">
      <thead>
        <tr style="background: var(--cream);">
          <th style="padding: 0.6rem 0.8rem; text-align: left; color: var(--blue); letter-spacing: 0.1em; font-size: 0.75rem; text-transform: uppercase;">Počet</th>
          <th style="padding: 0.6rem 0.8rem; text-align: center; color: var(--blue); letter-spacing: 0.1em; font-size: 0.75rem; text-transform: uppercase;">Malé motív</th>
          <th style="padding: 0.6rem 0.8rem; text-align: center; color: var(--blue); letter-spacing: 0.1em; font-size: 0.75rem; text-transform: uppercase;">Stredné motív</th>
          <th style="padding: 0.6rem 0.8rem; text-align: center; color: var(--blue); letter-spacing: 0.1em; font-size: 0.75rem; text-transform: uppercase;">Zľava</th>
        </tr>
      </thead>
      <tbody>
        <tr style="border-top: 1px solid #e0e5f0;">
          <td style="padding: 0.6rem 0.8rem; font-weight: 700;">1 – 9 ks</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center;">€ 15,00</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center;">€ 25,00</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center; color: #999;">–</td>
        </tr>
        <tr style="border-top: 1px solid #e0e5f0; background: #f9fbff;">
          <td style="padding: 0.6rem 0.8rem; font-weight: 700;">10 – 19 ks</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center;">€ 8,00</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center;">€ 17,00</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center; color: var(--gold); font-weight: 700;">– 47 %</td>
        </tr>
        <tr style="border-top: 1px solid #e0e5f0;">
          <td style="padding: 0.6rem 0.8rem; font-weight: 700;">20+ ks</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center;">€ 5,50</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center;">€ 12,00</td>
          <td style="padding: 0.6rem 0.8rem; text-align: center; color: var(--gold); font-weight: 700;">– 63 %</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="result-card">
    <div class="result-title">Ihr Orientierungspreis</div>
    <div class="result-row">
      <span class="label">Stückpreis</span>
      <span class="value" id="r-per-piece">€ 15,00</span>
    </div>
    <div class="result-row">
      <span class="label">Anzahl</span>
      <span class="value" id="r-qty">1 Stück</span>
    </div>
    <div class="result-row">
      <span class="label">Stickpreis gesamt</span>
      <span class="value" id="r-stick">€ 15,00</span>
    </div>
    <div class="result-row">
      <span class="label">Einmalige Programmierungskosten</span>
      <span class="value" id="r-prog">€ 25,00</span>
    </div>
    <div class="result-total">
      <span class="label">Gesamtpreis</span>
      <span class="value" id="r-total">€ 40,00</span>
    </div>
    <p class="note">Orientierungspreise exkl. MwSt. · Endpreis abhängig von Motiv und Detailgrad · Programmierungskosten fallen nur einmalig an</p>
    <a href="mailto:g.l.stickerei@gmail.com" class="cta">Unverbindlich anfragen</a>
  </div>

</div>

<script>
  const prices = {
    size: { small: { base: 15, bulk10: 8, bulk20: 5.5 }, medium: { base: 25, bulk10: 17, bulk20: 12 } },
    prog: { standard: 25, logo: 75 }
  };

  let selected = { size: 'small', prog: 'standard' };

  function selectOption(group, value, el) {
    selected[group] = value;
    document.querySelectorAll(`#${group}-options .option`).forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    calculate();
  }

  function changeQty(delta) {
    const input = document.getElementById('qty');
    let val = parseInt(input.value) + delta;
    if (val < 1) val = 1;
    input.value = val;
    calculate();
  }

  function calculate() {
    const qty = Math.max(1, parseInt(document.getElementById('qty').value) || 1);
    const sizeData = prices.size[selected.size];
    const progCost = prices.prog[selected.prog];

    let perPiece;
    if (qty >= 20) perPiece = sizeData.bulk20;
    else if (qty >= 10) perPiece = sizeData.bulk10;
    else perPiece = sizeData.base;

    const stickTotal = perPiece * qty;
    const total = stickTotal + progCost;

    document.getElementById('r-per-piece').textContent = `€ ${perPiece.toFixed(2).replace('.', ',')}`;
    document.getElementById('r-qty').textContent = `${qty} Stück`;
    document.getElementById('r-stick').textContent = `€ ${stickTotal.toFixed(2).replace('.', ',')}`;
    document.getElementById('r-prog').textContent = `€ ${progCost.toFixed(2).replace('.', ',')}`;
    document.getElementById('r-total').textContent = `€ ${total.toFixed(2).replace('.', ',')}`;
  }
</script>
</body>
</html>